# =============================================================================
#  Backend — DEVELOPMENT Dockerfile  (hot reload via dotnet watch)
#  Place this file at:  backend/Dockerfile.dev
# =============================================================================

FROM mcr.microsoft.com/dotnet/sdk:8.0

WORKDIR /app

# Enable polling file watcher (required for hot reload inside Docker on Windows)
ENV DOTNET_USE_POLLING_FILE_WATCHER=1
ENV DOTNET_WATCH_SUPPRESS_MSBUILD_INCREMENTALISM=1
ENV ASPNETCORE_URLS=http://+:8080

EXPOSE 8080

# Copy project files first so restore is cached unless .csproj changes
COPY *.sln ./
COPY src/GenService.Domain/GenService.Domain.csproj           src/GenService.Domain/
COPY src/GenService.Application/GenService.Application.csproj src/GenService.Application/
COPY src/GenService.Infrastructure/GenService.Infrastructure.csproj src/GenService.Infrastructure/
COPY src/GenService.API/GenService.API.csproj                 src/GenService.API/
COPY tests/GenService.UnitTests/GenService.UnitTests.csproj   tests/GenService.UnitTests/

RUN dotnet restore

# Copy all source
COPY . .

# Start with hot reload — any code change triggers automatic rebuild
ENTRYPOINT ["dotnet", "watch", "--project", "src/GenService.API/GenService.API.csproj", "run", "--urls", "http://0.0.0.0:8080"]
